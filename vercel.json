{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": ["gru1"],
  "functions": {
    "pages/api/upload.ts": {
      "maxDuration": 30
    },
    "pages/api/forms/[id]/export.ts": {
      "maxDuration": 30,
      "memory": 1024
    },
    "pages/api/admin/export-all.ts": {
      "maxDuration": 60,
      "memory": 1024
    }
  }
}
