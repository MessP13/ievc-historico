# Supabase (get from supabase.com dashboard)
DATABASE_URL="postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres"

# Next.js public (safe to expose)
NEXT_PUBLIC_SUPABASE_URL="https://[ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[anon-key]"

# Server-only
SUPABASE_SERVICE_ROLE_KEY="[service-role-key]"

# Cloudflare R2 Storage (for file uploads)
R2_ACCOUNT_ID="[account-id]"
R2_ACCESS_KEY_ID="[access-key]"
R2_SECRET_ACCESS_KEY="[secret-key]"
R2_BUCKET_NAME="ievc-historico"
NEXT_PUBLIC_R2_PUBLIC_URL="https://pub-[hash].r2.dev"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: protect admin/export API routes
ADMIN_API_KEY="[set-a-random-secret]"
